    {
      "quest_id": "side_002",
      "title": "湖底的秘密",
      "category": "side",
      "description": "渔女伊芙琳发现月影湖最近水质异常，她怀疑湖底有污染源，需要纯净样本和特殊容器来研究。",
      "objective": "取得湖心水晶、净水晶瓶和银鳞鱼尾，交给伊芙琳。",
