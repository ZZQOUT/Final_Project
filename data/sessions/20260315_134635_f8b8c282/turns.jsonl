{"session_id": "20260315_134635_f8b8c282", "turn_index": 6, "timestamp": "2026-03-15T13:52:55.365371+00:00", "player_text": "走啊", "npc_id": "npc_002", "location_id": "loc_003", "model_used": "qwen3-max-2026-01-23", "output": {"narration": "托比见你终于准备出发，赶紧小跑两步跟上，一边紧张地盯着通往铁砧镇的小路。", "npc_dialogue": [{"npc_id": "npc_002", "text": "太好了！那我们现在就走吧！我……我会紧紧跟着你的，千万别丢下我啊！哥布林最喜欢从树后面突然跳出来……"}], "world_updates": {"player_location": "loc_003", "npc_moves": [{"npc_id": "npc_002", "from_location": "loc_001", "to_location": "loc_003", "trigger": "player_instruction", "reason": "玩家同意陪同前往铁砧镇", "permanence": "temporary", "confidence": 0.9}], "flags_delta": {}, "quest_updates": {}, "quest_progress_updates": [], "inventory_delta": {}, "npc_personality_updates": []}, "memory_summary": "玩家确认出发，托比放心跟随，并一同前往铁砧镇。", "safety": {"refuse": false, "reason": null}}, "move_rejections": [], "move_refusals": [], "move_applied_count": 1, "move_rejected_count": 0, "move_refused_count": 0, "guard_warnings": [], "rag": {"enabled": true, "always_include_ids": ["20260315_134635_f8b8c282:world_bible:-:-:-:-:801c6423", "20260315_134635_f8b8c282:location:-:loc_001:-:-:0586f9cb", "20260315_134635_f8b8c282:npc_profile:npc_002:-:-:-:501e7337", "20260315_134635_f8b8c282:memory:npc_002:loc_001:1:-:76b0d1f9", "20260315_134635_f8b8c282:memory:npc_002:loc_001:2:-:54e5fb91", "20260315_134635_f8b8c282:memory:npc_002:loc_001:3:-:5d7d210a", "20260315_134635_f8b8c282:memory:npc_002:loc_001:4:-:4bc5bb55", "20260315_134635_f8b8c282:memory:npc_002:loc_001:5:-:9f9e9f6f", "20260315_134635_f8b8c282:summary:-:-:3:-:eea3d41b", "20260315_134635_f8b8c282:summary:-:-:4:-:467e736a", "20260315_134635_f8b8c282:summary:-:-:5:-:50db07b4"], "retrieved_ids": [], "retrieval_backend": "persistent_hybrid", "embedding_backend": "hashing", "vectorstore_path": "data/vectorstore/20260315_134635_f8b8c282", "filters": [{"session_id": "20260315_134635_f8b8c282", "npc_id": "npc_002", "doc_type": ["memory", "summary", "lore"]}, {"session_id": "20260315_134